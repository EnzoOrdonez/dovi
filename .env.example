# ============================================================
# DOVI — Environment (self-host single-tenant)
# Copia a .env y rellena. NUNCA commitear .env.
# ============================================================

# --- Auth (single shared API key; header X-DOVI-Token) ---
DOVI_API_KEY=change_me_to_a_long_random_string

# --- LLM cloud (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL_DEFAULT=claude-opus-4-6
ANTHROPIC_MODEL_DOWNGRADE=claude-haiku-4-5-20251001

# --- LLM local (optional, detectado JIT por extensión) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Vector store ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=chunk
QDRANT_VECTOR_SIZE=1024
# Quantization: none | scalar_int8  (NUNCA binary — destruye recall BGE-M3)
QDRANT_QUANTIZATION=none

# --- Queue / cache ---
REDIS_URL=redis://redis:6379/0

# --- ASR ---
WHISPER_MODEL_SIZE=small
WHISPER_COMPUTE_TYPE=int8_float16
WHISPER_DEVICE=auto

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=auto

# --- Budget guard ---
SESSION_USD_BUDGET=0.50

# --- Manifest roundtrip ---
MANIFEST_REQUEST_TIMEOUT_SEC=3.0
MANIFEST_REDIS_TTL_SEC=60

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=chrome-extension://*
